@startuml
title Final Project - Financial Management Diagram

top to bottom direction
hide circle
hide methods

scale 1.15

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam linetype ortho
skinparam backgroundColor white
skinparam defaultFontName Arial
skinparam defaultFontSize 15
skinparam nodesep 35
skinparam ranksep 85

skinparam packageStyle rectangle

skinparam package {
  BorderColor #CBD5E1
  BackgroundColor #F8FAFC
  FontColor #0F172A
  FontSize 16
}

skinparam class {
  BorderColor #334155
  BackgroundColor #FFFFFF
  HeaderBackgroundColor #E2E8F0
  FontColor #0F172A
  FontSize 14
  AttributeFontSize 13
  AttributeFontColor #334155
}

skinparam arrow {
  Color #64748B
  Thickness 1.2
  FontColor #334155
  FontSize 12
}

skinparam note {
  BackgroundColor #FFF7ED
  BorderColor #FB923C
  FontColor #7C2D12
  FontSize 12
}

package "Core Data" {
  class User {
    +id: bigint
    +name: string
    +email: string
    +requested_role: string
  }

  class Course {
    +id: bigint
    +code: string
    +name: string
    +price: integer
  }
}

package "Student Tuition Management" {
  class StudentTuition {
    +id: bigint
    +student_id: bigint
    +course_id: bigint
    +course_price: integer
  }

  class TuitionPayment {
    +id: bigint
    +student_id: bigint
    +parent_id: bigint
    +recorded_by: bigint
    +amount: integer
    +paid_on: date
    +method: string
  }

  class ScholarshipActivation {
    +id: bigint
    +parent_id: bigint
    +student_id: bigint?
    +offer_key: string
    +discount_percent: decimal
  }
}

package "Employee Payment Management" {
  class EmployeePayment {
    +id: bigint
    +employee_id: bigint
    +recorded_by: bigint
    +expected_salary: integer
    +amount_paid: integer
  }
}

package "Financial Services" {
  class TuitionFinancialService {
    +calculateSummary()
    +calculateRemainingBalance()
    +calculateDiscounts()
  }

  class EmployeePaymentService {
    +calculateStatus()
    +calculateRemainingSalary()
  }
}

User -down-> StudentTuition : student
Course -down-> StudentTuition : course price

StudentTuition -down-> TuitionPayment : tuition payments
ScholarshipActivation -down-> StudentTuition : discount

User -down-> TuitionPayment : pays / records
User -down-> ScholarshipActivation : parent / student

User -down-> EmployeePayment : employee / admin

StudentTuition -down-> TuitionFinancialService : tuition data
TuitionPayment -down-> TuitionFinancialService : payment data
ScholarshipActivation -down-> TuitionFinancialService : discount data

EmployeePayment -down-> EmployeePaymentService : salary data

note right of StudentTuition
  Created after student approval.
  Stores selected course and price.
end note

note right of TuitionPayment
  Stores tuition payments.
  Used for paid amount and balance.
end note

note right of EmployeePayment
  Tracks staff salary payments.
end note

@enduml